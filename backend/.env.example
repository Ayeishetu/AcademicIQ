SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ───────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./academic_rag.db
# Production (Supabase PostgreSQL — use the "Transaction" pooler connection string):
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Supabase Storage ───────────────────────────────────────────────────────────
# Leave empty for local dev (files saved to ./uploads instead)
# Required in production for persistent file storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_BUCKET=documents

# ── Vector DB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Anthropic API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
